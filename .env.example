# Credenciales del administrador
ADMIN_USER=superadmin
ADMIN_PASS=cambia_esta_contraseña

# Clave secreta para las sesiones (usar un valor aleatorio largo en producción)
SESSION_SECRET=cambia_esta_clave_secreta_aleatoria

# URL de la base de datos (por defecto SQLite local)
# Para SQLite en carpeta /data (recomendado con Docker para persistencia):
DATABASE_URL=sqlite:////app/data/ping_pong.db
# Para PostgreSQL (producción recomendada):
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/ping_pong

# Puerto en el que corre la app (usado por docker-compose)
PORT=8000
